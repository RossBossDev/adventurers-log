NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
LOG_LEVEL=debug
REDIS_URL=redis://localhost:6379

# Better Auth
# Production example: https://osrs-log.rossboss.dev
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=local-dev-better-auth-secret-change-me
# Production should include https://osrs-log.rossboss.dev. Add future iOS URL schemes here when implemented.
BETTER_AUTH_TRUSTED_ORIGINS=https://osrs-log.rossboss.dev,http://localhost:3000,http://localhost:3001

# Email OTP via Resend. Local/test without RESEND_API_KEY logs OTPs instead of sending.
AUTH_EMAIL_FROM=Adventurers' Log <auth@rossboss.dev>
RESEND_API_KEY=

# Google sign-in. Required for Google login to work.
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple sign-in. Required for Apple login to work.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_BASE64=
APPLE_APP_BUNDLE_IDENTIFIER=
